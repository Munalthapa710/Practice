@page
@model BulkyWebRazor_temp.Pages.Categories.IndexModel
<partial name="_Notification" />


<div class="row pt-4 pb-3">
<div class="col-6">
    <h2 class="text-primary">
        Category List
    </h2>
</div>
<div class="col-6 text-end">
    <a asp-page="Categories/create"  class="btn text-primary">
       <i class="bi bi-plus-cirle"></i>Create new category 
    </a>
</div>
</div>
<table class=" table table-border table-striped">
    <thead>
    <tr>
        <th>
CategoryName
</th>
<th>
    DisplayOrder
</th>
<th>
    Edit
</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var obj in Model.CategoryList){   <tr>
        <td>
           @obj.Name
        </td>
        <td>
            @obj.DisplayOrder
        </td>
        <td>
            <div class="w-75 btn-group" role="group">
                <a asp-page="Category/edit" asp-route-id="@obj.Id" class="btn btn-primary mx-2">
                    Edit 
                </a>
                        <a asp-page="Category/delete"  asp-route-id="@obj.Id"  class="btn btn-danger mx-2">
                            Delete
                        </a>
            </div>
        </td>
    </tr>}
 
    
    </tbody>
</table>
