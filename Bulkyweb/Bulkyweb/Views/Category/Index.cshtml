@model List<Category>
<div class="row pt-4 pb-3">
<div class="col-6">
    <h2 class="text-primary">
        Category List
    </h2>
</div>
<div class="col-6 text-end">
    <a asp-controller="Category" asp-action="Create" class="btn text-primary">
       <i class="bi bi-plus-cirle"></i>Create new category 
    </a>
</div>
</div>
<table class=" table table-border table-striped">
    <thead>
    <tr>
        <th>
CategoryName
</th>
<th>
    DisplayOrder
</th>
<th>
    Edit
</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var obj in Model){   <tr>
        <td>
           @obj.Name
        </td>
        <td>
            @obj.DisplayOrder
        </td>
        <td>
            <div class="w-75 btn-group" role="group">
                <a asp-controller="Category" asp-action="Edit" class="btn btn-primary mx-2">
                    Edit 
                </a>
                        <a asp-controller="Category" asp-action="Delete" class="btn btn-danger mx-2">
                            Delete
                        </a>
            </div>
        </td>
    </tr>}
 
    
    </tbody>
</table>